# ════════════════════════════════════════════════════════════
# .gitignore — seo-aeo-geo-auditor
# ════════════════════════════════════════════════════════════

# === SECRETS — NEVER COMMIT ===
*.env
.env
.env.local
.env.*.local
!.env.example
api_keys.txt
Api_AI.txt
*_api_key*
*.secret
secrets/
tokens/

# === GENERATED REPORTS (live data, per-domain) ===
reports/
history/
*.snapshot.json
artifacts/
*.artifact.html

# Allow sample reports under examples/sample-reports/
!examples/sample-reports/**

# === SCRATCH JSON / MD (root-level test runs) ===
*.json
!package.json
!package-lock.json
!.github/**/*.json

*.md.bak
_smoke_*.md
_smoke_*.json
_tmp_*.json
_smoke_*.py
last_report.json

# Common ad-hoc filenames used during development
psi_*.md
psi_*.json
final.json
final.md
final_*.json
final_*.md
adv*.json
val*.json
val*.md
kw*.json
kw*.md
wynik.json
before.json
after.json
after_*.json
after_*.md
probe.md
probe.json
schema_validation.*

# Markdown generated for ad-hoc audits at repo root
# (everything inside docs/, examples/sample-reports/ stays tracked)
/_*.md

# === PYTHON ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# === IDE / EDITORS ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === LOGS ===
*.log
logs/

# === GENERATED DESKTOP ASSETS ===
# icon.ico is rebuilt by tools/install_desktop_shortcut.ps1 on each install
tools/icon.ico

# === BACKUPS ===
*.bak
*_backup*
backups/
