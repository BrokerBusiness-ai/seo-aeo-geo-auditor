# =============================================================================
# .env.example — copy to .env and fill in your keys.
# Never commit .env. The .gitignore rule excludes it.
# =============================================================================

# ─── Google PageSpeed Insights ───────────────────────────────────────────────
# Free 25 000 calls/day. Get one at: https://aistudio.google.com/apikey
PSI_API_KEY=

# ─── LLM Provider Keys (used by aeo_probe.py) ────────────────────────────────
# At least ONE provider key enables the AEO probe to run. Each key unlocks
# one source LLM that the probe queries to test whether your domain is cited.

# OpenAI — gpt-4o-mini (~$0.15 per 1M input tokens)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — claude-3-5-haiku
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# DeepSeek — deepseek-chat (cheapest)
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# xAI Grok — grok-2-mini
# https://console.x.ai
XAI_API_KEY=

# Google Gemini — gemini-2.5-flash (free tier available)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Perplexity — sonar (search-grounded)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ─── Optional: GUI port + bind ───────────────────────────────────────────────
# Default 127.0.0.1:8765 — only loopback. Override only if you know why.
# AUDITOR_GUI_HOST=127.0.0.1
# AUDITOR_GUI_PORT=8765
